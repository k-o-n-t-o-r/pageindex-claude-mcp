# Claude OAuth token (passed through to Claude Agent SDK)
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Model name: sonnet, opus, haiku, or a full model ID
# CLAUDE_MODEL=sonnet

# Reasoning effort for Claude Agent SDK: low, medium, high, or max.
# Leave unset for the SDK default.
# CLAUDE_EFFORT=medium

# Document store location
# PAGEINDEX_STORE_PATH=~/.pageindex-store

# Log file location
# PAGEINDEX_LOG_FILE=~/.pageindex-store/mcp_server.log

# Max concurrent indexing jobs
# PAGEINDEX_CONCURRENCY=4

# Restrict import paths to this directory (recommended when running over SSE).
# Paths are resolved with symlinks before the check.
# PAGEINDEX_IMPORT_DIR=~/Documents/pageindex-imports
